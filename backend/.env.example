# ── Required ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── CORS: your frontend URL(s) ────────────────────────────────────────────────
# Comma-separated list. Localhost ports are always allowed automatically.
# For Netlify:   FRONTEND_URL=https://your-site.netlify.app
# For custom:    FRONTEND_URL=https://www.fairlens.ai
# For multiple:  FRONTEND_URL=https://fairlens.netlify.app,https://www.fairlens.ai
FRONTEND_URL=http://localhost:5173

# ── Optional ──────────────────────────────────────────────────────────────────
# FAIRLENS_DATA_DIR=./data          # where audit JSON records are stored
# COMPLIANCE_STORE_DIR=./data/compliance
# PORT=8000
